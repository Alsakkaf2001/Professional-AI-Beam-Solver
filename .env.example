# Professional AI Beam Solver — Environment Configuration
# Copy this file to .env and fill in your credentials

# LemonFox AI (https://lemonfox.ai)
LEMONFOX_API_KEY=your_lemonfox_api_key_here

# Flask
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Upload
MAX_UPLOAD_SIZE=10485760
LOG_LEVEL=INFO
